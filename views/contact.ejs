<%- include('partials/header') %>

<h1 class="mb-3">Kontak Kami</h1>
<% if (typeof query !== 'undefined' && query.success) { %>
	<div class="alert alert-success">Pesan Anda telah terkirim.</div>
<% } %>
<div class="row">
	<div class="col-md-8">
		<div class="card shadow-sm">
			<div class="card-body">
				<form method="POST" action="/kontak">
					<div class="mb-3">
						<label class="form-label">Nama</label>
						<input required type="text" name="name" class="form-control" />
					</div>
					<div class="mb-3">
						<label class="form-label">Email</label>
						<input required type="email" name="email" class="form-control" />
					</div>
					<div class="mb-3">
						<label class="form-label">Pesan</label>
						<textarea required name="message" rows="5" class="form-control"></textarea>
					</div>
					<button class="btn btn-primary" type="submit">Kirim</button>
				</form>
			</div>
		</div>
	</div>
</div>

<%- include('partials/footer') %>